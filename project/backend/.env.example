OPENROUTER_API_KEY=your-openrouter-key
OPENROUTER_MODEL=anthropic/claude-3.5-sonnet
 
# Optional LiteLLM gateway (takes precedence when both variables are set)
LITE_LLM_URL=localhost:4000
LITELLM_MASTER_KEY=your-lite-llm-master-key
# Optional model for LiteLLM (defaults to OPENROUTER_MODEL when omitted)
LITELLM_MODEL=openrouter/nvidia/nemotron-3-super-120b-a12b:free
